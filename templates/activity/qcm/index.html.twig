{% extends 'base.html.twig' %}

{% block title %}Vocabulaire - Wakatta!
{% endblock %}

{% block body %}
	<div class="px-4 pb-10 pt-4 w-full max-w-sm" data-controller="qcm">
		<h1 class="titre-page">Vocabulaire</h1>

		<div class="mb-4">
			{% include 'dashboard/_progress_bar.html.twig' with {
				label: 'Question',
				current: questionNumber,
				needed: 5,
				percent: (questionNumber / 5 * 100),
				suffix: '',
				color: 'bg-bleu-aiiro',
				textColor: 'text-bleu-aiiro'
				} %}
		</div>

		<div class="bg-white rounded-lg shadow-sm border border-gris-pierre p-6 text-center mb-6">
			{% if question.difficulty.value == 'facile' %}
				<p class="font-jp text-4xl mb-2">{{ question.vocabulary.hiragana }}</p>
				<p class="text-encre/60">{{ question.vocabulary.romaji }}</p>
			{% elseif question.difficulty.value == 'moyen' %}
				<p class="text-2xl font-semibold mb-2">{{ question.vocabulary.french }}</p>
				<p class="text-encre/60">{{ question.vocabulary.romaji }}</p>
			{% else %}
				<p class="text-2xl font-semibold">{{ question.vocabulary.french }}</p>
			{% endif %}
		</div>

		<form method="post" action="{{ path('app_activity_vocabulaire_reponse') }}" data-turbo-frame="qcm-result-frame">

			<input type="hidden" name="vocabularyId" value="{{ question.vocabulary.id }}">
			<input type="hidden" name="difficulty" value="{{ question.difficulty.value }}">
			<input type="hidden" name="sessionId" value="{{ session.id }}">
			<input type="hidden" name="answer" data-qcm-target="answerInput" value="">

			<div class="space-y-4 mb-8">
				{% for choice in question.choices %}
					<button type="button" data-qcm-target="choice" data-action="click->qcm#select" data-qcm-value-param="{{ choice }}" class="w-full text-center border-2 border-bleu-aiiro rounded-lg py-3 font-jp text-lg font-normal transition-all">
						{{ choice }}
					</button>
				{% endfor %}
			</div>

			<button type="submit" data-qcm-target="submitBtn" disabled class="btn w-full disabled:opacity-40 disabled:cursor-not-allowed">
				Valider
			</button>
		</form>

		<turbo-frame id="qcm-result-frame"></turbo-frame>
	</div>
{% endblock %}
