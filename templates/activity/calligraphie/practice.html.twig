{% extends 'base.html.twig' %}

{% block title %}
	Hiragana - Calligraphie - Wakatta!
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block body %}
	<div class="flex items-center justify-between w-full mb-1">
		<p class="text-encre/50 text-sm font-semibold uppercase tracking-wide">Hiragana</p>
		<a href="{{ path('app_activity_calligraphie') }}" class="inline-flex items-center gap-0.5 text-encre/50 text-xs font-semibold">
			<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
				<path d="M19 12H5"/>
				<path d="m12 19-7-7 7-7"/>
			</svg>
			Retour sélection
		</a>
	</div>
	<h1 class="titre-page">Calligraphie</h1>
	<div class="flex flex-col items-center" data-controller="calligraphie" data-calligraphie-romaji-value="{{ hiragana.romaji }}" data-calligraphie-svg-url-value="{{ asset('animcjk/' ~ hiragana.romaji ~ '.svg') }}" data-calligraphie-evaluation-url-value="{{ path('app_activity_calligraphie_evaluation', {hiragana: hiragana.romaji}) }}">

		<h2 class="titre-page">{{ hiragana.character }}
			<span class="text-xl text-encre/60">({{ hiragana.romaji }})</span>
		</h2>

		{# Zone de tracé : le SVG animé et le canvas de dessin sont superposés #}
		<div class="relative rounded-lg border border-gris-pierre" style="width: 320px; height: 320px; background-color: white; background-image: repeating-linear-gradient(0deg, #D9D4CC 0 1px, transparent 1px 40px), repeating-linear-gradient(90deg, #D9D4CC 0 1px, transparent 1px 40px);">
			<div data-calligraphie-target="animationContainer" class="absolute inset-0"></div>
			<canvas data-calligraphie-target="canvas" width="320" height="320" class="absolute inset-0" style="touch-action: none; cursor: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%2210%22><circle cx=%225%22 cy=%225%22 r=%224%22 fill=%22%23C8463C%22/></svg>') 5 5, crosshair;"></canvas>
		</div>


		{# Toolbar #}
		<div style="width: 358px;" class="mt-6">
			{% include 'components/_toolbar.html.twig' with {
        buttons: [
            {icon: 'replay', action: 'calligraphie#replay', label: 'Rejouer'},
            {icon: 'undo', action: 'calligraphie#undo', label: 'Annuler'},
            {icon: 'redo', action: 'calligraphie#redo', label: 'Rétablir'},
        ],
        validate_action: 'calligraphie#validate',
        validate_label: 'Valider',
    } %}
		</div>
	</div>
{% endblock %}
